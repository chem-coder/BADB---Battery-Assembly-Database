{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tape_prepare.v1",
  "title": "Tape Preparation Submission",
  "description": "Data package for tape preparation process: recipe actuals + process steps (mixing, coating, drying, calendering).",
  "type": "object",
  "required": [
    "contract_version",
    "submission_type",
    "submission_id",
    "created_at",
    "user",
    "machine",
    "checksum",
    "payload"
  ],
  "properties": {
    "contract_version": {
      "const": "tape_prepare.v1",
      "description": "Contract identifier and version"
    },
    "submission_type": {
      "const": "tape_prepare",
      "description": "Type of data submission"
    },
    "submission_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique submission identifier (generated by VBA client)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when submission was created"
    },
    "user": {
      "type": "string",
      "minLength": 1,
      "description": "Login of the operator who created the submission"
    },
    "machine": {
      "type": "string",
      "description": "Hostname of the machine where Excel is running"
    },
    "checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the payload JSON (for integrity verification)"
    },
    "payload": {
      "type": "object",
      "required": [
        "project_id",
        "tape_recipe_id",
        "tape_name",
        "actuals",
        "steps"
      ],
      "properties": {
        "project_id": {
          "type": "integer",
          "minimum": 1,
          "description": "FK → projects.project_id"
        },
        "tape_recipe_id": {
          "type": "integer",
          "minimum": 1,
          "description": "FK → tape_recipes.tape_recipe_id"
        },
        "tape_name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable tape name"
        },
        "tape_status": {
          "type": "string",
          "enum": ["ok", "experimental", "discarded"],
          "default": "ok",
          "description": "Tape status (PostgreSQL ENUM: tape_status)"
        },
        "notes": {
          "type": ["string", "null"],
          "description": "Optional notes about the tape"
        },
        "actuals": {
          "type": "array",
          "minItems": 1,
          "description": "Recipe line actuals — what was actually weighed/measured",
          "items": {
            "type": "object",
            "required": [
              "recipe_line_id",
              "measure_mode",
              "material_instance_id"
            ],
            "properties": {
              "recipe_line_id": {
                "type": "integer",
                "minimum": 1,
                "description": "FK → tape_recipe_lines.recipe_line_id"
              },
              "measure_mode": {
                "type": "string",
                "enum": ["mass", "volume"],
                "description": "How the material was measured (PostgreSQL ENUM: measure_mode)"
              },
              "actual_mass_g": {
                "type": ["number", "null"],
                "minimum": 0,
                "description": "Actual mass in grams (required if measure_mode='mass')"
              },
              "actual_volume_ml": {
                "type": ["number", "null"],
                "minimum": 0,
                "description": "Actual volume in milliliters (required if measure_mode='volume')"
              },
              "material_instance_id": {
                "type": "integer",
                "minimum": 1,
                "description": "FK → material_instances.instance_id — specific batch/lot of material"
              }
            },
            "if": {
              "properties": { "measure_mode": { "const": "mass" } }
            },
            "then": {
              "required": ["actual_mass_g"],
              "properties": {
                "actual_mass_g": { "type": "number" },
                "actual_volume_ml": { "const": null }
              }
            },
            "else": {
              "required": ["actual_volume_ml"],
              "properties": {
                "actual_volume_ml": { "type": "number" },
                "actual_mass_g": { "const": null }
              }
            }
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "description": "Process steps performed on the tape, in order",
          "items": {
            "type": "object",
            "required": [
              "operation_type",
              "performed_by",
              "started_at"
            ],
            "properties": {
              "operation_type": {
                "type": "string",
                "enum": [
                  "drying_am",
                  "weighing",
                  "mixing",
                  "coating",
                  "drying_tape",
                  "calendering",
                  "drying_pressed_tape"
                ],
                "description": "Operation type code (matches operation_types.code in DB)"
              },
              "performed_by": {
                "type": "string",
                "minLength": 1,
                "description": "Login of the operator who performed this step"
              },
              "started_at": {
                "type": "string",
                "format": "date-time",
                "description": "When the step was started"
              },
              "comments": {
                "type": ["string", "null"],
                "description": "Optional comments about this step"
              },
              "params": {
                "type": "object",
                "description": "Step-specific parameters (schema depends on operation_type)",
                "oneOf": [
                  {
                    "title": "Mixing parameters",
                    "properties": {
                      "slurry_volume_ml": { "type": ["number", "null"] },
                      "dry_mixing_id": { "type": ["integer", "null"] },
                      "dry_start_time": { "type": ["string", "null"], "format": "date-time" },
                      "dry_duration_min": { "type": ["integer", "null"], "minimum": 0 },
                      "dry_rpm": { "type": ["string", "null"] },
                      "wet_mixing_id": { "type": ["integer", "null"] },
                      "wet_start_time": { "type": ["string", "null"], "format": "date-time" },
                      "wet_duration_min": { "type": ["integer", "null"], "minimum": 0 },
                      "wet_rpm": { "type": ["string", "null"] }
                    },
                    "additionalProperties": false
                  },
                  {
                    "title": "Coating parameters",
                    "properties": {
                      "foil_id": { "type": ["integer", "null"], "description": "FK → foils.foil_id" },
                      "coating_id": { "type": ["integer", "null"], "description": "FK → coating_methods.coating_id" }
                    },
                    "additionalProperties": false
                  },
                  {
                    "title": "Drying parameters",
                    "properties": {
                      "temperature_c": { "type": ["number", "null"] },
                      "atmosphere": { "type": ["string", "null"] },
                      "target_duration_min": { "type": ["integer", "null"], "minimum": 0 },
                      "other_parameters": { "type": ["string", "null"] }
                    },
                    "additionalProperties": false
                  },
                  {
                    "title": "Calendering parameters",
                    "properties": {
                      "temp_c": { "type": ["number", "null"] },
                      "pressure_value": { "type": ["number", "null"] },
                      "pressure_units": { "type": ["string", "null"] },
                      "draw_speed_m_min": { "type": ["number", "null"] },
                      "other_params": { "type": ["string", "null"] },
                      "init_thickness_microns": { "type": ["number", "null"] },
                      "final_thickness_microns": { "type": ["number", "null"] },
                      "no_passes": { "type": ["integer", "null"], "minimum": 1 },
                      "appearance": { "type": ["string", "null"] }
                    },
                    "additionalProperties": false
                  },
                  {
                    "title": "No parameters (weighing, drying_am)",
                    "maxProperties": 0
                  }
                ]
              }
            }
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
