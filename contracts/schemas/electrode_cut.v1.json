{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "electrode_cut.v1",
  "title": "Electrode Cut Batch Submission",
  "description": "Data package for electrode cutting process: cut batch parameters, individual electrodes, optional drying and foil mass measurements.",
  "type": "object",
  "required": [
    "contract_version",
    "submission_type",
    "submission_id",
    "created_at",
    "user",
    "machine",
    "checksum",
    "payload"
  ],
  "properties": {
    "contract_version": {
      "const": "electrode_cut.v1",
      "description": "Contract identifier and version"
    },
    "submission_type": {
      "const": "electrode_cut",
      "description": "Type of data submission"
    },
    "submission_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique submission identifier (generated by VBA client)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when submission was created"
    },
    "user": {
      "type": "string",
      "minLength": 1,
      "description": "Login of the operator who created the submission"
    },
    "machine": {
      "type": "string",
      "description": "Hostname of the machine where Excel is running"
    },
    "checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the payload JSON (for integrity verification)"
    },
    "payload": {
      "type": "object",
      "required": [
        "tape_id",
        "shape",
        "electrodes"
      ],
      "properties": {
        "tape_id": {
          "type": "integer",
          "minimum": 1,
          "description": "FK → tapes.tape_id — source tape for this cut batch"
        },
        "shape": {
          "type": "string",
          "enum": ["circle", "rectangle"],
          "description": "Shape of cut electrodes"
        },
        "diameter_mm": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Diameter for circle electrodes (required if shape='circle')"
        },
        "length_mm": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Length for rectangle electrodes (required if shape='rectangle')"
        },
        "width_mm": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Width for rectangle electrodes (required if shape='rectangle')"
        },
        "comments": {
          "type": ["string", "null"],
          "description": "Optional comments about the cut batch"
        },
        "electrodes": {
          "type": "array",
          "minItems": 1,
          "description": "Individual electrodes cut from this batch",
          "items": {
            "type": "object",
            "required": [
              "electrode_mass_g"
            ],
            "properties": {
              "electrode_mass_g": {
                "type": "number",
                "exclusiveMinimum": 0,
                "description": "Mass of the individual electrode in grams"
              },
              "cup_number": {
                "type": ["integer", "null"],
                "minimum": 1,
                "description": "Cup/position number in the batch"
              },
              "comments": {
                "type": ["string", "null"],
                "description": "Optional comments about this electrode"
              }
            },
            "additionalProperties": false
          }
        },
        "drying": {
          "type": ["object", "null"],
          "description": "Optional electrode drying parameters (if drying was performed)",
          "properties": {
            "start_time": {
              "type": "string",
              "format": "date-time",
              "description": "When drying started"
            },
            "end_time": {
              "type": ["string", "null"],
              "format": "date-time",
              "description": "When drying ended (null if still in progress)"
            },
            "temperature_c": {
              "type": ["number", "null"],
              "description": "Drying temperature in Celsius"
            },
            "other_parameters": {
              "type": ["string", "null"],
              "description": "Free-text drying parameters (atmosphere, etc.)"
            },
            "comments": {
              "type": ["string", "null"],
              "description": "Optional comments about drying"
            }
          },
          "required": ["start_time"],
          "additionalProperties": false
        },
        "foil_mass_measurements": {
          "type": ["array", "null"],
          "description": "Optional foil mass measurements for this batch",
          "items": {
            "type": "object",
            "required": ["mass_g"],
            "properties": {
              "mass_g": {
                "type": "number",
                "exclusiveMinimum": 0,
                "description": "Foil mass in grams (must be > 0)"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "if": {
        "properties": { "shape": { "const": "circle" } }
      },
      "then": {
        "required": ["tape_id", "shape", "electrodes", "diameter_mm"]
      },
      "else": {
        "required": ["tape_id", "shape", "electrodes", "length_mm", "width_mm"]
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
