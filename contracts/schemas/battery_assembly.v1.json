{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "battery_assembly.v1",
  "title": "Battery Assembly Submission",
  "description": "Data package for battery assembly: electrodes, electrolyte, configuration, and optional QC measurements.",
  "type": "object",
  "required": [
    "contract_version",
    "submission_type",
    "submission_id",
    "created_at",
    "user",
    "machine",
    "checksum",
    "payload"
  ],
  "properties": {
    "contract_version": {
      "const": "battery_assembly.v1",
      "description": "Contract identifier and version"
    },
    "submission_type": {
      "const": "battery_assemble",
      "description": "Type of data submission"
    },
    "submission_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique submission identifier (generated by VBA client)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when submission was created"
    },
    "user": {
      "type": "string",
      "minLength": 1,
      "description": "Login of the operator who created the submission"
    },
    "machine": {
      "type": "string",
      "description": "Hostname of the machine where Excel is running"
    },
    "checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the payload JSON (for integrity verification)"
    },
    "payload": {
      "type": "object",
      "required": [
        "project_id",
        "form_factor",
        "electrodes"
      ],
      "properties": {
        "project_id": {
          "type": "integer",
          "minimum": 1,
          "description": "FK → projects.project_id"
        },
        "form_factor": {
          "type": "string",
          "minLength": 1,
          "description": "Battery form factor (e.g. 'coin', 'pouch', 'cylindrical')"
        },
        "status": {
          "type": "string",
          "enum": ["assembled", "testing", "completed", "failed", "disassembled"],
          "default": "assembled",
          "description": "Battery status (PostgreSQL ENUM: battery_status)"
        },
        "notes": {
          "type": ["string", "null"],
          "description": "Optional notes about the assembly"
        },
        "electrodes": {
          "type": "array",
          "minItems": 1,
          "description": "Electrodes used in this battery",
          "items": {
            "type": "object",
            "required": [
              "electrode_id",
              "role"
            ],
            "properties": {
              "electrode_id": {
                "type": "integer",
                "minimum": 1,
                "description": "FK → electrodes.electrode_id"
              },
              "role": {
                "type": "string",
                "enum": ["cathode", "anode"],
                "description": "Electrode role in the battery (PostgreSQL ENUM: electrode_role)"
              },
              "position_index": {
                "type": ["integer", "null"],
                "minimum": 0,
                "description": "Position index in the battery stack (0-based)"
              }
            },
            "additionalProperties": false
          }
        },
        "electrolyte": {
          "type": ["object", "null"],
          "description": "Electrolyte used in the battery (null if not yet added)",
          "properties": {
            "electrolyte_id": {
              "type": "integer",
              "minimum": 1,
              "description": "FK → electrolytes.electrolyte_id"
            }
          },
          "required": ["electrolyte_id"],
          "additionalProperties": false
        },
        "qc": {
          "type": ["object", "null"],
          "description": "Optional QC measurements taken immediately after assembly",
          "properties": {
            "ocv_v": {
              "type": ["number", "null"],
              "description": "Open Circuit Voltage in volts"
            },
            "esr_mohm": {
              "type": ["number", "null"],
              "description": "Equivalent Series Resistance in milliohms"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
